* {
    background:     {{colors.background.default.hex_alpha | set_alpha: 0.5}};
    foreground:     {{colors.on_surface.default.hex}};
    foreground-alt: {{colors.secondary.default.hex}};
    selected:       {{colors.primary.default.hex}};
    text:           {{colors.on_surface_variant.default.hex}};
    text-alt:       {{colors.on_primary.default.hex}};
    border-color:   {{colors.outline.default.hex_alpha | set_alpha: 0.7}};
}
