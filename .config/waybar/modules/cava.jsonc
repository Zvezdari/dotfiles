{
"cava": {
	"framerate": 60,
	"bars": 8,
	"sensitivity": 1,
	"lower_cutoff_freq": 50,
	"higher_cutoff_freq": 20000,
	"sleep_timer": 15,
	"hide_on_silence": true,
	"method": "pulse",
	"source": "auto",
	"stereo": false,
	"bar_delimiter": 0,
	"monstercat": true,
	"noise_reduction": 0.03,
	"input_delay": 1,
	"format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ]
}
}
