{
"cava": {
	"framerate": 60,
	"bars": 5,
	"sensitivity": 1,
	"lower_cutoff_freq": 50,
	"higher_cutoff_freq": 10000,
	"sleep_timer": 5,
	"hide_on_silence": true,
	"method": "pulse",
	"source": "auto",
	"stereo": false,
	"bar_delimiter": 0,
	"monstercat": false,
	"noise_reduction": 0.03,
	"input_delay": 4,
	"format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█" ],
  "on-click": "exec kitty -e rmpc"
}
}
